# PostgreSQL
POSTGRES_USER=detection_user
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT
POSTGRES_DB=detection_db
DATABASE_URL=postgresql://detection_user:GANTI_PASSWORD_KUAT@postgres:5432/detection_db

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=GANTI_PASSWORD_KUAT
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=detection-storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=GANTI_PASSWORD_KUAT

# JWT — gunakan random string panjang, contoh: openssl rand -hex 32
SECRET_KEY=GANTI_SECRET_KEY_MINIMAL_32_KARAKTER
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Tax API
TAX_API_BASE_URL=https://api.example.com
TAX_API_KEY=your-tax-api-key

# Superadmin default (dibuat otomatis saat startup jika belum ada)
SUPERADMIN_EMAIL=admin@detection.local
SUPERADMIN_PASSWORD=GANTI_PASSWORD_KUAT

# Review queue webhook (kosongkan untuk nonaktif)
REVIEW_WEBHOOK_URL=
REVIEW_QUEUE_ALERT_THRESHOLD=50

# Batas durasi video (detik)
MAX_VIDEO_DURATION_SEC=600

# CORS — sesuaikan dengan domain/IP load balancer
BACKEND_CORS_ORIGINS=["http://34.111.182.163"]

# Frontend build-time env (dipakai docker-compose build args)
NEXT_PUBLIC_API_URL=http://34.111.182.163
NEXT_PUBLIC_WS_URL=ws://34.111.182.163
