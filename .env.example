# =============================================================================
# PANDUAN KONFIGURASI
# -----------------------------------------------------------------------------
# 1. Salin file ini menjadi .env  →  cp .env.example .env
# 2. Ganti semua nilai yang ditandai <...> dengan nilai nyata
# 3. JANGAN commit file .env ke git
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL
# DATABASE_URL harus cocok dengan POSTGRES_USER / PASSWORD / DB di atas
# -----------------------------------------------------------------------------
POSTGRES_USER=detection_user
POSTGRES_PASSWORD=<password-kuat-postgres>
POSTGRES_DB=detection_db
DATABASE_URL=postgresql://detection_user:<password-kuat-postgres>@postgres:5432/detection_db


# -----------------------------------------------------------------------------
# Redis
# Tidak perlu diubah jika pakai docker-compose default
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# MinIO (object storage untuk video & crop gambar)
#
# ATURAN PENTING:
#   MINIO_ROOT_USER  == MINIO_ACCESS_KEY  (harus sama persis)
#   MINIO_ROOT_PASSWORD == MINIO_SECRET_KEY  (harus sama persis)
#
# MINIO_ENDPOINT   : hostname internal Docker — jangan diubah
# MINIO_PUBLIC_URL : URL publik yang bisa diakses browser
#                    Format: http://<IP-server>:9000
#                    Port 9000 harus terbuka di firewall
# MINIO_BUCKET     : nama bucket, dibuat otomatis saat startup
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<password-kuat-minio>
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_URL=http://<IP-server-publik>:9000
MINIO_BUCKET=detection-storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<password-kuat-minio>


# -----------------------------------------------------------------------------
# JWT Authentication
#
# SECRET_KEY : string acak minimal 32 karakter
#   Generate  →  openssl rand -hex 32
# ACCESS_TOKEN_EXPIRE_MINUTES  : masa berlaku access token (default 15 menit)
# REFRESH_TOKEN_EXPIRE_DAYS    : masa berlaku refresh token (default 7 hari)
# -----------------------------------------------------------------------------
SECRET_KEY=<openssl-rand-hex-32>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# Tax API (Samsat / e-Samsat Jawa Barat)
#
# TAX_API_BASE_URL : base URL endpoint API pajak
# TAX_API_KEY      : API key / token yang diberikan penyedia
# -----------------------------------------------------------------------------
TAX_API_BASE_URL=https://api.example.com
TAX_API_KEY=<api-key-pajak>


# -----------------------------------------------------------------------------
# Superadmin default
#
# Akun ini dibuat OTOMATIS saat backend pertama kali start (jika belum ada).
# Setelah login, ganti password melalui menu Manajemen User.
# SUPERADMIN_EMAIL bisa diisi format bebas (tidak harus email valid).
# -----------------------------------------------------------------------------
SUPERADMIN_EMAIL=admin
SUPERADMIN_PASSWORD=<password-kuat-admin>


# -----------------------------------------------------------------------------
# Active Learning — Review Queue
#
# REVIEW_WEBHOOK_URL           : URL webhook yang dipanggil saat antrian review
#                                mencapai threshold (kosongkan untuk nonaktif)
# REVIEW_QUEUE_ALERT_THRESHOLD : jumlah item PENDING sebelum webhook dipicu
# MAX_VIDEO_DURATION_SEC       : batas durasi video yang boleh diupload (detik)
# -----------------------------------------------------------------------------
REVIEW_WEBHOOK_URL=
REVIEW_QUEUE_ALERT_THRESHOLD=50
MAX_VIDEO_DURATION_SEC=600


# -----------------------------------------------------------------------------
# CORS & Frontend URLs
#
# BACKEND_CORS_ORIGINS : daftar origin yang diizinkan, format JSON array
#                        Gunakan domain/IP publik server (dengan port jika perlu)
# NEXT_PUBLIC_API_URL  : URL backend API yang diakses dari browser
# NEXT_PUBLIC_WS_URL   : URL WebSocket untuk live progress deteksi
#
# Contoh lokal  : http://localhost
# Contoh produksi: http://34.101.133.152
# -----------------------------------------------------------------------------
BACKEND_CORS_ORIGINS=["http://<IP-server-publik>"]
NEXT_PUBLIC_API_URL=http://<IP-server-publik>
NEXT_PUBLIC_WS_URL=ws://<IP-server-publik>
